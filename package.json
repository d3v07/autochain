{
  "name": "autochain",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "seed": "turbo seed --filter=@autochain/db",
    "clean": "turbo clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2",
    "typescript": "^5.7"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": ">=20"
  }
}
